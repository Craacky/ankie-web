{
  email {$ACME_EMAIL}
}

{$DOMAIN} {
  encode zstd gzip

  log {
    output stdout
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "geolocation=(), camera=(), microphone=()"
    Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://api.fontshare.com; font-src 'self' data: https://api.fontshare.com https://cdn.fontshare.com; script-src 'self' https://telegram.org; connect-src 'self' https://telegram.org https://oauth.telegram.org"
  }

  @api path /api/*
  reverse_proxy @api backend:8000
  reverse_proxy frontend:80
}
