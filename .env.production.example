# Domain for HTTPS (must point A/AAAA record to your VPS IP)
DOMAIN=ankie.example.com

# Email for Let's Encrypt ACME notifications
ACME_EMAIL=you@example.com

# Telegram auth
TELEGRAM_BOT_USERNAME=ankie_auth_helper_bot
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Session and import behavior
SESSION_TTL_DAYS=30
COOKIE_SECURE=true
AUTO_IMPORT_SOURCES=true

# Notes bootstrap from private GitHub repository (one-time per user)
NOTES_BOOTSTRAP_REPO=owner/private-notes-repo
NOTES_BOOTSTRAP_BRANCH=master
GITHUB_TOKEN=ghp_replace_with_fine_grained_token
NOTES_ROOT=/data/notes
