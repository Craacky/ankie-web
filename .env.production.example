# Domain for HTTPS (must point A/AAAA record to your VPS IP)
DOMAIN=ankie.example.com

# Email for Let's Encrypt ACME notifications
ACME_EMAIL=you@example.com

# Telegram auth
TELEGRAM_BOT_USERNAME=ankie_auth_helper_bot
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Session behavior and limits
SESSION_TTL_DAYS=30
SESSION_CLEANUP_INTERVAL_SECONDS=300
COOKIE_SECURE=true
CORS_ORIGINS=https://ankie.example.com
ALLOW_CORS_ANY=false
ENABLE_API_DOCS=false
DISABLE_RATE_LIMITING=false
ALLOW_UNSAFE_NOTES_ROOT=false
NOTES_UPLOAD_MAX_BYTES=5242880
COLLECTIONS_IMPORT_MAX_BYTES=5242880
CARD_QUESTION_MAX_CHARS=2000
CARD_ANSWER_MAX_CHARS=8000
NOTES_ROOT=/data/notes
